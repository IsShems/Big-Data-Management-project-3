# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me

# PostgreSQL (CDC source)
PG_USER=cdc_user
PG_PASSWORD=change-me

# Jupyter
JUPYTER_TOKEN=change-me

# Airflow UI
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=change-me

# Debezium connector name (must match Kafka Connect registration)
CDC_CONNECTOR_NAME=pg-cdc-connector

# Kafka topic for CDC customers (Airflow branch + Spark bronze)
CDC_KAFKA_TOPIC=dbserver1.public.customers

# Container name Spark jobs use when Airflow runs docker exec
JUPYTER_CONTAINER_NAME=jupyter
